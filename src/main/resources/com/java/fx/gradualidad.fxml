<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="574.0" prefWidth="998.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutualidad.modulo_credito.Controllers.GradualidadController">
   <children>
      <Label layoutX="34.0" layoutY="28.0" text="Cálculo de Gradualidad" textFill="#39577c">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="34.0" layoutY="82.0" text="Número de Socio:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtNumSocio" layoutX="196.0" layoutY="76.0" onAction="#cargarConTecla" prefHeight="39.0" prefWidth="135.0" promptText="Ej. 100" />
      <Button fx:id="btnCalcular" layoutX="338.0" layoutY="76.0" mnemonicParsing="false" onAction="#cargarCreditos" style="-fx-background-color: #185754;" text="Calcular" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Button fx:id="btnLimpiar" layoutX="434.0" layoutY="76.0" mnemonicParsing="false" onAction="#limpiar" style="-fx-background-color: #212691;" text="Limpiar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <TableView fx:id="tblCreditos" layoutX="36.0" layoutY="184.0" onMouseClicked="#mostrarGradualidad" prefHeight="249.0" prefWidth="926.0">
        <columns>
          <TableColumn fx:id="colFolio" prefWidth="152.0" sortable="false" text="FOLIO" />
          <TableColumn fx:id="colMonto" prefWidth="206.0" sortable="false" text="MONTO" />
            <TableColumn fx:id="colTasa" prefWidth="172.0" sortable="false" text="TASA" />
            <TableColumn fx:id="colEstado" prefWidth="172.0" sortable="false" text="ESTADO" />
            <TableColumn fx:id="colVencido" prefWidth="223.0" sortable="false" text="¿ESTUVO VENCIDO?" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label layoutX="34.0" layoutY="131.0" text="Nombre de Socio:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtNomSocio" editable="false" layoutX="196.0" layoutY="125.0" prefHeight="39.0" prefWidth="509.0" />
      <Button fx:id="btnImprimir" layoutX="864.0" layoutY="441.0" mnemonicParsing="false" onAction="#generarReporte" style="-fx-background-color: #185754;" text="Imprimir" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Label alignment="CENTER_RIGHT" layoutX="40.0" layoutY="456.0" prefHeight="27.0" prefWidth="261.0" text="Gradualidad Correspondiente:">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtGrad" editable="false" layoutX="310.0" layoutY="450.0" prefHeight="39.0" prefWidth="98.0" />
      <Label layoutX="21.0" layoutY="502.0" text="Meses en los que el prestamo venció:">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtVeces" editable="false" layoutX="310.0" layoutY="496.0" prefHeight="39.0" prefWidth="98.0" />
      <ImageView fx:id="imgBusqueda" fitHeight="30.0" fitWidth="26.0" layoutX="534.0" layoutY="80.0" onMouseClicked="#buscarSocioPorNombre" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@/assets/images/icono-busqueda.png" />
         </image>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </ImageView>
      <Label fx:id="lblAviso" layoutX="415.0" layoutY="456.0" prefHeight="27.0" prefWidth="432.0" text="Label" visible="false">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
   </children>
</Pane>
