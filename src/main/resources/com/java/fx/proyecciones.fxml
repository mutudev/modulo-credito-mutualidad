<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="574.0" prefWidth="998.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mutualidad.modulo_credito.Controllers.ProyeccionController">
   <children>
      <Label layoutX="34.0" layoutY="28.0" text="Proyecciones de Crédito" textFill="#39577c">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="44.0" layoutY="93.0" text="Monto:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtMonto" layoutX="117.0" layoutY="87.0" onAction="#cargarTipos" prefHeight="39.0" prefWidth="210.0" />
      <Label layoutX="55.0" layoutY="146.0" text="Plazo:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbPlazo" layoutX="117.0" layoutY="140.0" prefHeight="39.0" prefWidth="210.0" />
      <Label layoutX="347.0" layoutY="93.0" text="Tipo:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbTasa" layoutX="400.0" layoutY="140.0" prefHeight="39.0" prefWidth="210.0" />
      <CheckBox fx:id="chkIVA" layoutX="112.0" layoutY="199.0" mnemonicParsing="false" text="Calcular IVA">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </CheckBox>
      <Button fx:id="btnCalcular" layoutX="628.0" layoutY="140.0" mnemonicParsing="false" onAction="#cargarProyeccion" prefHeight="39.0" prefWidth="95.0" style="-fx-background-color: #185754;" text="Calcular" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Button fx:id="btnLimpiar" layoutX="742.0" layoutY="140.0" mnemonicParsing="false" onAction="#limpiar" prefHeight="39.0" prefWidth="95.0" style="-fx-background-color: #212691;" text="Limpiar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Label layoutX="347.0" layoutY="146.0" text="Tasa:">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbTipo" layoutX="400.0" layoutY="87.0" prefHeight="39.0" prefWidth="439.0" />
      <TableView fx:id="tblProyeccion" layoutX="44.0" layoutY="246.0" prefHeight="238.0" prefWidth="909.0">
        <columns>
          <TableColumn fx:id="colCuota" prefWidth="93.0" text="CUOTA" />
          <TableColumn fx:id="colFecha" prefWidth="117.0" text="FECHA" />
            <TableColumn fx:id="colCapital" prefWidth="123.0" text="CAPITAL" />
            <TableColumn fx:id="colIntereses" prefWidth="130.0" text="INTERESES" />
            <TableColumn fx:id="colIVA" prefWidth="107.0" text="IVA" />
            <TableColumn fx:id="colTotal" prefWidth="130.0" text="TOTAL" />
            <TableColumn fx:id="colSaldo" prefWidth="123.0" text="SALDO" />
            <TableColumn fx:id="colDias" prefWidth="87.0" text="DÍAS" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button fx:id="btnImprimir" layoutX="830.0" layoutY="495.0" mnemonicParsing="false" onAction="#generarReporte" prefHeight="39.0" prefWidth="123.0" style="-fx-background-color: #185754;" text="Imprimir" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
   </children>
</Pane>
